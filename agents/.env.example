# agents/.env.example
# このファイルを .env にコピーして値を設定してください
# cp agents/.env.example .env

# ── Anthropic API ──
ANTHROPIC_API_KEY=sk-ant-xxxx
CLAUDE_MODEL=claude-opus-4-5

# ── 見積・注文管理システム（GAS Web App URL）──
GAS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GAS_REQUEST_TIMEOUT=30

# ── メール設定（Gmail の例）──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=your-app-password       # Gmailのアプリパスワード
MAIL_FROM=your-account@gmail.com
SALES_NOTIFY_EMAIL=sales@yourcompany.com
PROCUREMENT_EMAIL=procurement@yourcompany.com

# ── ERP（販売管理システム）──
ERP_BASE_URL=https://erp.yourcompany.com/api/v1
ERP_API_KEY=your-erp-api-key
ERP_TIMEOUT=20

# ── Gemini API（直接OCRを使う場合）──
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash-latest

# ── 動作モード ──
# true = 実際の送信・登録は行わない（開発・テスト時推奨）
MAIL_DRY_RUN=true
ERP_DRY_RUN=true

# 単価の許容誤差（1% = 0.01）
PRICE_TOLERANCE_RATE=0.01
