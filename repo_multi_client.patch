+    var kwAttrs   = c.isFallback ? 'disabled placeholder="（一致しなかった案件が入る受け皿）" style="background:#f0f0f0;"' : '';
+    var delAttrs  = c.isFallback ? 'disabled title="その他は削除できません" style="opacity:.35;cursor:not-allowed;"' : '';
+    return `
+      <div style="display:flex;align-items:center;gap:8px;padding:6px 8px;border:1px solid var(--border);border-radius:8px;background:#fafbfc;">
+        <input type="text" value="${_escAttr(c.name)}" placeholder="例：藤商事" ${nameAttrs}
+          style="flex:1;min-width:120px;padding:5px 8px;border:1px solid var(--border);border-radius:6px;" onchange="_updClientMaster(${i},'name',this.value)">
+        <input type="text" value="${_escAttr(kwStr)}" placeholder="例：藤商事, 株式会社藤商事" ${kwAttrs}
+          style="flex:1;min-width:140px;padding:5px 8px;border:1px solid var(--border);border-radius:6px;" onchange="_updClientMaster(${i},'keywords',this.value)">
+        <input type="text" value="${_escAttr(c.driveFolderUrl || '')}" placeholder="https://drive.google.com/drive/folders/..."
+          style="flex:2;min-width:220px;padding:5px 8px;border:1px solid var(--border);border-radius:6px;" onchange="_updClientMaster(${i},'driveFolderUrl',this.value)">
+        <button class="btn btn-outline btn-sm" ${delAttrs} onclick="deleteClientMasterItem(${i})" title="削除" style="color:var(--danger);border-color:var(--danger);">✕</button>
+      </div>`;
+  }).join('');
+}
+
+function _updClientMaster(i, field, value) {
+  if (!_editClientMaster[i]) return;
+  if (field === 'keywords') {
+    _editClientMaster[i].keywords = String(value || '').split(/[,、\s]+/).filter(Boolean);
+  } else {
+    _editClientMaster[i][field] = value;
+  }
+}
+
+function addClientMasterItem() {
+  _editClientMaster.splice(_editClientMaster.length - (_editClientMaster.some(function(c){return c.isFallback;}) ? 1 : 0), 0, {
+    id: 'client_' + Date.now().toString(36),
+    name: '', keywords: [], driveFolderUrl: '', isFallback: false
+  });
+  renderClientMasterList();
+}
+
+function deleteClientMasterItem(i) {
+  var c = _editClientMaster[i];
+  if (!c || c.isFallback) return;
+  if (!confirm('「' + (c.name || '(未入力)') + '」を取引先一覧から削除しますか？')) return;
+  _editClientMaster.splice(i, 1);
+  renderClientMasterList();
+}
+
+function saveClientMasterAdmin() {
+  var invalid = _editClientMaster.some(function (c) { return !c.isFallback && !String(c.name || '').trim(); });
+  if (invalid) { showToast('取引先名が空欄の行があります', true); return; }
+  google.script.run.withSuccessHandler(function (res) {
+    if (res && res.success) {
+      showToast('✅ 取引先マスタを保存しました');
+      _editClientMaster = res.items || _editClientMaster;
+      renderClientMasterList();
+      loadClientMasterList(); // 案件一覧のタブへ即反映
+    } else {
+      showToast('保存に失敗しました: ' + (res ? res.error : '不明'), true);
+    }
+  }).withFailureHandler(function (err) {
+    showToast('通信エラー: ' + err.message, true);
+  }).handleApiRequest('clientMasterSave', { list: _editClientMaster });
 }
 
