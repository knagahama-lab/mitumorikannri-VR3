+// 案件一覧の「注文書一覧／見積書一覧」タブ用データ読み込み
+function loadClientMasterList() {
+  google.script.run.withSuccessHandler(function (res) {
+    if (res && res.success) {
+      _clientMasterList = res.items || [];
+      renderOrderClientTabs();
+      renderQuoteClientTabs();
+    }
+  }).withFailureHandler(function () { /* サイレント失敗（タブ非表示のまま） */ }).handleApiRequest('clientMasterList', null);
+}
+
+// 顧客名から取引先マスタのタブ名を判定（未一致は「その他」グループの表示名）
+function _matchClientGroup(name) {
+  var n = String(name || '');
+  var list = _clientMasterList || [];
+  for (var i = 0; i < list.length; i++) {
+    var c = list[i];
+    if (c.isFallback) continue;
+    var kws = (c.keywords && c.keywords.length) ? c.keywords : [c.name];
+    for (var j = 0; j < kws.length; j++) {
+      if (kws[j] && n.indexOf(kws[j]) !== -1) return c.name;
+    }
+  }
+  var fallback = list.filter(function (c) { return c.isFallback; })[0];
+  return fallback ? fallback.name : 'その他';
+}
+
+function _clientTabOrder() {
+  var list = _clientMasterList || [];
+  var main = list.filter(function (c) { return !c.isFallback; }).map(function (c) { return c.name; });
+  var fallback = list.filter(function (c) { return c.isFallback; }).map(function (c) { return c.name; });
+  return main.concat(fallback.length ? fallback : ['その他']);
+}
+
+function _renderClientTabButtons(containerId, names, activeName, onClick) {
+  var el = document.getElementById(containerId);
+  if (!el) return;
+  var all = ['すべて'].concat(names);
+  el.innerHTML = all.map(function (name) {
+    var val = (name === 'すべて') ? 'all' : name;
+    var active = (val === activeName);
+    var style = 'padding:5px 14px;border-radius:16px;font-size:12.5px;font-weight:600;cursor:pointer;border:1px solid ' +
+      (active ? 'var(--primary)' : 'var(--border)') + ';background:' + (active ? 'var(--primary)' : '#fff') + ';color:' + (active ? '#fff' : 'var(--text-sub)') + ';';
+    return '<button style="' + style + '" onclick="' + onClick + '(\'' + _escAttr(val) + '\')">' + _escAttr(name) + '</button>';
+  }).join('');
+}
+
+function renderOrderClientTabs() {
+  _renderClientTabButtons('order-client-tabs', _clientTabOrder(), _orderClientTab, 'setOrderClientTab');
+}
+function renderQuoteClientTabs() {
+  _renderClientTabButtons('quote-client-tabs', _clientTabOrder(), _quoteClientTab, 'setQuoteClientTab');
+}
+function setOrderClientTab(name) { _orderClientTab = name; renderOrderClientTabs(); applyFilters(); }
+function setQuoteClientTab(name) { _quoteClientTab = name; renderQuoteClientTabs(); applyQuoteFilter(); }
+
